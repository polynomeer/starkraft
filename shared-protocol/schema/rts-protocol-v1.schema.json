{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://starkraft.dev/schema/rts-protocol-v1.schema.json",
  "title": "Starkraft RTS Protocol v1 Envelope",
  "type": "object",
  "required": ["protocolVersion", "simVersion", "message"],
  "properties": {
    "protocolVersion": {
      "type": "integer",
      "const": 1
    },
    "simVersion": {
      "type": "string",
      "minLength": 1
    },
    "buildHash": {
      "type": ["string", "null"]
    },
    "message": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "clientName"],
          "properties": {
            "type": {"const": "handshake"},
            "clientName": {"type": "string", "minLength": 1},
            "requestedRoom": {"type": ["string", "null"]}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "roomId", "clientId", "serverTickMs", "protocolVersion"],
          "properties": {
            "type": {"const": "handshakeAck"},
            "roomId": {"type": "string", "minLength": 1},
            "clientId": {"type": "string", "minLength": 1},
            "serverTickMs": {"type": "integer", "minimum": 1},
            "protocolVersion": {"type": "integer", "minimum": 1},
            "resumeToken": {"type": ["string", "null"]}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "tick", "commands"],
          "properties": {
            "type": {"const": "commandBatch"},
            "tick": {"type": "integer", "minimum": 0},
            "commands": {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "object",
                    "required": ["commandType", "unitIds", "x", "y"],
                    "properties": {
                      "commandType": {"const": "move"},
                      "requestId": {"type": ["string", "null"]},
                      "unitIds": {"type": "array", "items": {"type": "integer"}, "minItems": 1},
                      "x": {"type": "number"},
                      "y": {"type": "number"}
                    },
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "required": ["commandType", "unitIds", "targetUnitId"],
                    "properties": {
                      "commandType": {"const": "attack"},
                      "requestId": {"type": ["string", "null"]},
                      "unitIds": {"type": "array", "items": {"type": "integer"}, "minItems": 1},
                      "targetUnitId": {"type": "integer"}
                    },
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "required": ["commandType", "x", "y"],
                    "properties": {
                      "commandType": {"const": "build"},
                      "requestId": {"type": ["string", "null"]},
                      "x": {"type": "number"},
                      "y": {"type": "number"},
                      "unitType": {"type": ["string", "null"]}
                    },
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "required": ["commandType"],
                    "properties": {
                      "commandType": {"const": "queue"},
                      "requestId": {"type": ["string", "null"]},
                      "unitType": {"type": ["string", "null"]}
                    },
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "required": ["commandType"],
                    "properties": {
                      "commandType": {"const": "surrender"},
                      "requestId": {"type": ["string", "null"]}
                    },
                    "additionalProperties": false
                  }
                ]
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "tick", "commandType", "accepted"],
          "properties": {
            "type": {"const": "commandAck"},
            "tick": {"type": "integer", "minimum": 0},
            "requestId": {"type": ["string", "null"]},
            "commandType": {"type": "string", "minLength": 1},
            "accepted": {"type": "boolean"},
            "reason": {"type": "string"}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "tick", "worldHash"],
          "properties": {
            "type": {"const": "snapshot"},
            "tick": {"type": "integer", "minimum": 0},
            "worldHash": {"type": "integer"}
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["type", "tick"],
          "properties": {
            "type": {"const": "matchEnd"},
            "tick": {"type": "integer", "minimum": 0},
            "winnerId": {"type": ["string", "null"]}
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
